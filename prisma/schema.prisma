// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model users {
  id           Int           @id @default(autoincrement())
  username     String        @unique @db.VarChar(100)
  password     String        @db.VarChar(255)
  nama_lengkap String        @db.VarChar(150)
  created_at   DateTime      @default(now()) @db.Timestamp(0)
  updated_at   DateTime      @default(now()) @db.Timestamp(0)
  riwayat_stok riwayat_stok[]
}

model pengaturan {
  id             Int      @id @default(autoincrement())
  nama_toko      String?  @default("GlowAura SkinLab") @db.VarChar(150)
  tagline        String?  @default("Pancarkan Pesona Alami Kulitmu") @db.VarChar(255)
  deskripsi      String?  @db.Text
  no_wa_toko     String   @db.VarChar(20)
  url_logo       String?  @db.VarChar(255)
  link_instagram String?  @db.VarChar(255)
  link_facebook  String?  @db.VarChar(255)
  link_tiktok    String?  @db.VarChar(255)
  alamat         String?  @db.Text
  embed_maps     String?  @db.Text
  updated_at     DateTime @default(now()) @db.Timestamp(0)
}

model banners {
  id              Int      @id @default(autoincrement())
  judul_banner    String?  @db.VarChar(150)
  url_foto_banner String   @db.VarChar(255)
  link_tujuan     String?  @db.VarChar(255)
  urutan          Int?     @default(0)
  is_active       Boolean? @default(true)
  created_at      DateTime @default(now()) @db.Timestamp(0)
  updated_at      DateTime @default(now()) @db.Timestamp(0)
}

model kategori {
  id            Int      @id @default(autoincrement())
  nama_kategori String   @unique @db.VarChar(100)
  slug          String   @unique @db.VarChar(100)
  created_at    DateTime @default(now()) @db.Timestamp(0)
  updated_at    DateTime @default(now()) @db.Timestamp(0)
  produk        produk[]
}

model produk {
  id             Int            @id @default(autoincrement())
  nama_produk    String         @db.VarChar(150)
  deskripsi      String?        @db.Text
  harga_jual     Int
  harga_modal    Int
  stok_sekarang  Int?           @default(0)
  kategori_id    Int?
  url_foto       String         @db.VarChar(255)
  is_active      Boolean?       @default(true)
  created_at     DateTime       @default(now()) @db.Timestamp(0)
  updated_at     DateTime       @default(now()) @db.Timestamp(0)
  kategori       kategori?      @relation(fields: [kategori_id], references: [id], onDelete: SetNull)
  riwayat_stok   riwayat_stok[]
}

model riwayat_stok {
  id               Int      @id @default(autoincrement())
  produk_id        Int?
  jenis_stok       String   @db.VarChar(20) // Gunakan String karena MySQL ENUM bisa bermasalah di Prisma
  jumlah           Int
  harga_modal_real Int
  harga_jual_real  Int?     @default(0)
  metode_pembayaran String?  @default("CASH") @db.VarChar(50)
  keterangan       String?  @db.Text
  tanggal          DateTime @default(now()) @db.Timestamp(0)
  dicatat_oleh     Int?
  produk           produk?  @relation(fields: [produk_id], references: [id], onDelete: Cascade)
  users            users?   @relation(fields: [dicatat_oleh], references: [id])
}